{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperdustlab.github.io/COAT/schemas/concern.schema.json",
  "title": "Concern",
  "description": "First-class runtime unit. The runtime only distinguishes kind=concern|meta_concern; semantic types live in generated_type/generated_tags. Strict shape (no extra properties) is enforced by the pydantic envelope; the schema is intentionally extensible so MetaConcern can layer on top.",
  "type": "object",
  "required": ["id", "kind", "name", "schema_version"],
  "properties": {
    "id":              { "type": "string", "minLength": 1 },
    "kind":            { "type": "string", "enum": ["concern", "meta_concern"] },
    "generated_type":  { "type": "string" },
    "generated_tags":  { "type": "array", "items": { "type": "string" }, "uniqueItems": true, "default": [] },
    "name":            { "type": "string", "minLength": 1 },
    "description":     { "type": "string", "default": "" },

    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin"],
      "properties": {
        "origin": {
          "type": "string",
          "enum": [
            "user_input", "tool_result", "memory", "feedback",
            "host_explicit_plan", "draft_output", "environment_event",
            "system_default", "manual_import", "derived"
          ]
        },
        "ref":           { "type": "string" },
        "ts":            { "type": "string", "format": "date-time" },
        "trust":         { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },

    "joinpoint_selectors": {
      "type": "array",
      "items": { "$ref": "joinpoint.schema.json#/$defs/JoinpointSelector" },
      "default": []
    },
    "pointcut":        { "$ref": "pointcut.schema.json" },
    "advice":          { "$ref": "advice.schema.json" },
    "weaving_policy":  { "$ref": "weaving.schema.json#/$defs/WeavingPolicy" },

    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "crosscutting":        { "type": "boolean", "default": false },
        "duration":            { "type": "string", "enum": ["transient", "turn", "session", "long_term"], "default": "turn" },
        "joinpoint_coverage":  { "type": "array", "items": { "type": "string" }, "default": [] },
        "tenant_id":           { "type": "string" },
        "agent_session_id":    { "type": "string" }
      }
    },

    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target_concern_id", "relation_type"],
        "properties": {
          "target_concern_id": { "type": "string" },
          "relation_type": {
            "type": "string",
            "enum": [
              "activates", "suppresses", "constrains", "verifies",
              "conflicts_with", "depends_on", "generalizes", "specializes",
              "duplicates", "derived_from", "updates", "replaces", "supports"
            ]
          },
          "weight":  { "type": "number", "minimum": 0, "maximum": 1, "default": 1.0 },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "default": []
    },

    "activation_state": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "active":             { "type": "boolean", "default": false },
        "score":              { "type": "number", "minimum": 0, "maximum": 1 },
        "last_activated_at":  { "type": "string", "format": "date-time" },
        "decay":              { "type": "number", "minimum": 0, "default": 0 }
      }
    },

    "lifecycle_state": {
      "type": "string",
      "enum": [
        "created", "active", "reinforced", "weakened",
        "merged", "frozen", "archived", "deleted", "revived"
      ],
      "default": "created"
    },

    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "activations":  { "type": "integer", "minimum": 0, "default": 0 },
        "satisfied":    { "type": "integer", "minimum": 0, "default": 0 },
        "violated":     { "type": "integer", "minimum": 0, "default": 0 },
        "tokens_used":  { "type": "integer", "minimum": 0, "default": 0 }
      }
    },

    "created_at":  { "type": "string", "format": "date-time" },
    "updated_at":  { "type": "string", "format": "date-time" },
    "schema_version": { "type": "string", "default": "0.1.0" }
  }
}
