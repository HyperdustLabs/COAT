{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperdustlab.github.io/COAT/schemas/concern_vector.schema.json",
  "title": "ConcernVector",
  "description": "Sparse activation snapshot of the DCN for the current turn (v0.1 §17). Not an embedding — a structured runtime activation state.",
  "type": "object",
  "additionalProperties": false,
  "required": ["turn_id", "active_concerns"],
  "properties": {
    "turn_id":          { "type": "string" },
    "agent_session_id": { "type": "string" },
    "ts":               { "type": "string", "format": "date-time" },
    "schema_version":   { "type": "string", "default": "0.1.0" },
    "active_concerns": {
      "type": "array",
      "items": { "$ref": "#/$defs/ActiveConcern" }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_active_concerns":  { "type": "integer", "minimum": 1 },
        "max_injection_tokens": { "type": "integer", "minimum": 1 }
      }
    }
  },

  "$defs": {
    "ActiveConcern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["concern_id", "activation_score"],
      "properties": {
        "concern_id":       { "type": "string" },
        "activation_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "priority":         { "type": "number", "minimum": 0, "maximum": 1 },
        "confidence":       { "type": "number", "minimum": 0, "maximum": 1 },
        "injection_mode":   {
          "type": "string",
          "enum": [
            "reasoning_guidance", "planning_guidance", "decision_guidance",
            "tool_guard", "response_requirement", "verification_rule",
            "memory_write_guard", "reflection_prompt", "rewrite_guidance",
            "suppress_instruction", "escalation_notice", "verification_only"
          ]
        },
        "matched_joinpoint": { "type": "string" }
      }
    }
  }
}
