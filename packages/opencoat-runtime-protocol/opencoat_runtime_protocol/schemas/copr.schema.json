{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperdustlab.github.io/OpenCOAT/schemas/copr.schema.json",
  "title": "COPR",
  "description": "Concern-Oriented Prompt Representation — structured prompt tree (Thought DOM). Replaces flat prompt strings so pointcuts can match at sub-message granularity (v0.1 §16).",
  "type": "object",
  "additionalProperties": false,
  "required": ["prompt_id", "messages"],
  "properties": {
    "prompt_id":      { "type": "string", "minLength": 1 },
    "schema_version": { "type": "string", "default": "0.1.0" },
    "messages": {
      "type": "array",
      "items": { "$ref": "#/$defs/Message" }
    }
  },

  "$defs": {
    "Message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role"],
      "properties": {
        "id": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["system", "developer", "user", "assistant", "tool", "memory", "retrieved_context"]
        },
        "raw_text":  { "type": "string" },
        "sections":  {
          "type": "array",
          "items": { "$ref": "#/$defs/PromptSection" },
          "default": []
        },
        "spans":     {
          "type": "array",
          "items": { "$ref": "#/$defs/Span" },
          "default": []
        },
        "structure": { "$ref": "#/$defs/Structure" }
      }
    },
    "PromptSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path":      { "type": "string", "description": "e.g. 'system_prompt.rules'" },
        "raw_text":  { "type": "string" }
      }
    },
    "Span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id":            { "type": "string" },
        "text":          { "type": "string" },
        "semantic_type": { "type": "string", "description": "e.g. 'analysis_request', 'high_risk_action_request'" },
        "tokens":        { "type": "array", "items": { "type": "string" } },
        "char_range":    {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "Structure": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional structured payload (e.g. a parsed tool_call). Fields can be addressed via 'tool_call.arguments.amount'."
    }
  }
}
