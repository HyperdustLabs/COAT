{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperdustlab.github.io/OpenCOAT/schemas/weaving.schema.json",
  "title": "Weaving",
  "description": "Weaving primitives. v0.1 §15: 11 operations × multiple targets across 8 weaving levels.",
  "type": "object",

  "$defs": {
    "WeavingOperation": {
      "type": "string",
      "enum": [
        "insert", "replace", "suppress", "annotate",
        "warn", "verify", "rewrite", "defer",
        "escalate", "block", "compress"
      ]
    },
    "WeavingLevel": {
      "type": "string",
      "enum": [
        "prompt_level", "span_level", "token_level", "tool_level",
        "memory_level", "output_level", "verification_level", "reflection_level"
      ]
    },
    "WeavingPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode":        { "$ref": "#/$defs/WeavingOperation" },
        "level":       { "$ref": "#/$defs/WeavingLevel" },
        "target":      { "type": "string", "description": "e.g. 'runtime_prompt.verification_rules'" },
        "max_tokens":  { "type": "integer", "minimum": 1, "default": 200 },
        "priority":    { "type": "number", "minimum": 0, "maximum": 1, "default": 0.5 }
      }
    },
    "WeavingOp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "operation"],
      "properties": {
        "target":     { "type": "string" },
        "operation":  { "$ref": "#/$defs/WeavingOperation" },
        "level":      { "$ref": "#/$defs/WeavingLevel" },
        "content":    { "type": "string" },
        "condition":  { "type": "string", "description": "predicate expression evaluated against context" },
        "priority":   { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
