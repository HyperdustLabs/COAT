{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperdustlabs.github.io/OpenCOAT/schemas/advice.schema.json",
  "title": "Advice",
  "description": "Guidance / constraint produced when a Concern activates. 11 advice types per v0.1 §14.2.",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "content"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "reasoning_guidance",
        "planning_guidance",
        "decision_guidance",
        "tool_guard",
        "response_requirement",
        "verification_rule",
        "memory_write_guard",
        "reflection_prompt",
        "rewrite_guidance",
        "suppress_instruction",
        "escalation_notice"
      ]
    },
    "content":     { "type": "string", "minLength": 1 },
    "rationale":   { "type": "string" },
    "max_tokens":  { "type": "integer", "minimum": 1 },
    "params":      { "type": "object", "additionalProperties": true }
  }
}
