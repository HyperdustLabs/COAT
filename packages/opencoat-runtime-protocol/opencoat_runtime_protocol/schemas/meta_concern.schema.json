{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperdustlab.github.io/OpenCOAT/schemas/meta_concern.schema.json",
  "title": "MetaConcern",
  "description": "Specialization of Concern (kind=meta_concern) that governs the runtime itself rather than business semantics. The runtime supports 8 governance capabilities: extraction / separation / activation / conflict_resolution / verification / lifecycle / budget / evolution.",
  "type": "object",
  "required": ["governance_capability"],
  "allOf": [
    { "$ref": "concern.schema.json" },
    {
      "properties": {
        "kind": { "const": "meta_concern" }
      }
    }
  ],
  "properties": {
    "governance_capability": {
      "type": "string",
      "enum": [
        "extraction_control",
        "separation_control",
        "activation_control",
        "conflict_resolution",
        "verification_control",
        "lifecycle_control",
        "budget_control",
        "evolution_control"
      ]
    }
  }
}
